#!/usr/bin/env bash
# =============================================================================
# CR380 - Podman Lab — Configuration centrale / Central configuration
# =============================================================================
#
# FR: Modifier ce fichier pour mettre à jour les versions d'images, les noms
#     de conteneurs et les délais d'attente avant chaque session de cours.
# EN: Edit this file to update image versions, container names, and timeouts
#     before each class session.
# =============================================================================

# -----------------------------------------------------------------------------
# Images / Images
# -----------------------------------------------------------------------------
IMAGE_NGINX="docker.io/nginx:latest"
IMAGE_NGINX_ALPINE="docker.io/nginx:alpine"
IMAGE_ALPINE="docker.io/alpine:latest"
IMAGE_UBUNTU="docker.io/ubuntu:22.04"
IMAGE_PYTHON="docker.io/python:3.11-slim"
IMAGE_HELLO="quay.io/podman/hello"

# -----------------------------------------------------------------------------
# Noms de conteneurs / Container names
# -----------------------------------------------------------------------------
CT_ALPINE="alpineCT"
CT_NGINX="nginxCT"
CT_APP="appCT"
CT_VOL="volCT"

# -----------------------------------------------------------------------------
# Tags d'images construites / Built image tags
# -----------------------------------------------------------------------------
IMG_BASE="monimage:base"
IMG_SLIM="monimage:slim"

# -----------------------------------------------------------------------------
# Pods
# -----------------------------------------------------------------------------
POD_NAME="mypod"
CT_POD_NGINX="pod-nginx"
CT_POD_ALPINE="pod-alpine"

# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------
PORT_NGINX=8080
PORT_APP=8090

# -----------------------------------------------------------------------------
# Volumes
# -----------------------------------------------------------------------------
VOL_NAME="podman_data"
VOL_MOUNT="/data"

# -----------------------------------------------------------------------------
# Podman Compose
# -----------------------------------------------------------------------------
COMPOSE_DIR="${PROJECT_DIR}/compose-files"
COMPOSE_NGINX_BASIC="${COMPOSE_DIR}/nginx-basic.yaml"
CT_COMPOSE_NGINX="cr380-podman-nginx"
PORT_COMPOSE_NGINX=8081

# -----------------------------------------------------------------------------
# Délais d'attente / Timeouts (seconds)
# -----------------------------------------------------------------------------
TIMEOUT_DEFAULT=30
TIMEOUT_APT=600
TIMEOUT_BUILD=300
TIMEOUT_PULL=180
TIMEOUT_CONTAINER_READY=30

# -----------------------------------------------------------------------------
# Prérequis / Prerequisites
# -----------------------------------------------------------------------------
MIN_DISK_GB=10

# -----------------------------------------------------------------------------
# GitBook
# -----------------------------------------------------------------------------
GITBOOK_BASE_URL="https://app.gitbook.com/o/cr380/s/podman-lab"
